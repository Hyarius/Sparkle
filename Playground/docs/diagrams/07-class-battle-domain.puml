@startuml
title pg:: battle domain model (battle.md §1 — port of Unity Battle/Core + Abilities + Statuses)
hide empty members

class BattleContext {
  +playerUnits / enemyUnits
  +board : BoardData
  +currentTurn : TurnContext
  +allowsTaming / returnWorldCell
  +tryPlaceUnit/tryMoveUnit/trySwapUnits
  +defeatUnit/removeUnit
}
class BattleObject {
  +side : BattleSide
  +tags
}
class BattleUnit {
  +sourceUnit : CreatureUnit*
  +attributes : BattleAttributes
  +statuses : BattleStatuses
  +boardPosition?
  +isDefeated() / isActiveInBattle() / isTurnReady()
}
class WildBattleUnit {
  +tamingProgress
}
class BattleAttributes {
  +hp/ap/mp : ObservableResource
  +turnBar : ObservableFloatResource
  +staminaRate + combat stats : ObservableValue
  +shields : ObservableList<BattleShield>
  +absorbDamage(kind, amount)
}
BattleObject <|-- BattleUnit
BattleUnit <|-- WildBattleUnit
BattleUnit *-- BattleAttributes
BattleContext o-- BattleUnit
BattleContext o-- "BoardData"

abstract class BattleAction {
  +source : BattleUnit&
  +apCost() / mpCost()
}
class MoveAction {
  +destination / distance
}
class AbilityAction {
  +ability : const Ability&
  +targetCells
}
class EndTurnAction
BattleAction <|-- MoveAction
BattleAction <|-- AbilityAction
BattleAction <|-- EndTurnAction

class Ability <<definition>> {
  +cost {ap, mp}
  +range {shape, min, max, requiresLoS}
  +areaOfEffect {shape, value}
  +targetProfile
  +effects : vector<Effect>
}
abstract class Effect <<polymorphic>> {
  +apply(ExecutionContext&)
}
class Status <<definition>> {
  +tags / hookPoint
  +effects : vector<Effect>
}
class BattleStatuses {
  +entries {status, stacks, duration, isSourcePassive}
  +add/remove/contains
  +advanceTurnDurations()
}
Ability o-- Effect
Status o-- Effect
BattleUnit *-- BattleStatuses
BattleStatuses o-- Status
AbilityAction --> Ability

class BattleAbilityExecutionContext {
  +context / ability?
  +sourceObject / targetObject
  +anchorCell / affectedCell
}
Effect ..> BattleAbilityExecutionContext

abstract class BattleEvent {
  +turnIndex / sourceAbility? / caster? / target?
}
class BattleLog {
  +events (whole battle)
}
BattleEvent <|-- "Damage / Heal / AbilityCast / ShieldApplied\nDamageAbsorbed / ShieldBroken / StatusApplied\nStatusRemoved / UnitDefeated / BattleWon\nResourceConsumed/Changed/Stolen / DistanceTravelled\nTurnStarted / TurnEnded / HitSurvived / Teleported\nDisplacement / SwapPosition / TurnBar* / Revive"
BattleLog o-- BattleEvent
@enduml
