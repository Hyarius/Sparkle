@startuml
title Battle action resolution — player ability (battle.md §4)
actor Player
participant "PlayerTurnPhase\n(input bound)" as PT
participant "BattleActionValidator" as Val
participant "BoardOverlayState" as Ovl
participant "BattleCoordinator" as Coord
participant "ResolutionPhase" as ResP
participant "BattleActionResolver" as Res
participant "Effects" as Eff
participant "BattleResourceRules" as RR
participant "BattleLog / EventCenter" as Log

Player -> PT : press '2' (ability slot)
PT -> Val : getValidTargetCells(ctx, turn, ability)
Val --> PT : cells (range ∩ LoS ∩ profile)
PT -> Ovl : show ability range + hovered AoE + LoS shading
Player -> PT : click anchor cell (valid)
PT -> Coord : onActionChosen(AbilityAction{ability, cells})
Coord -> ResP : set pending action, transition
ResP -> Res : resolve(ctx, action)
Res -> Res : revalidate; spend AP/MP
Res -> Log : ResourceConsumed, AbilityCast{targetDistance}
loop each AoE cell (anchor order)
  Res -> Eff : effect.apply(ExecutionContext{source, target@cell,\nanchorCell, affectedCell})
  Eff -> RR : changeHealth / changeAp / … (clamped,\nfires OnHPLoss… status hooks)
  Eff -> Log : DamageEvent / HealEvent / StatusApplied / …
end
Res -> Res : resolvePendingDefeats\n(UnitDefeated events; wild → untamable)
ResP -> Coord : onResolved
alt turn can continue (MP/AP + legal options)
  Coord -> PT : back to PlayerTurnPhase
else
  Coord -> Coord : endTurn (hooks, durations,\nAP/MP refill, turnBar=0) → IdlePhase
end
note over Log : TamingService consumes battleEventOccurred live;\nFeatBoardService consumes the full log at battle end
@enduml
