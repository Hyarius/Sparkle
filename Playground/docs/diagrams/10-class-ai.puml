@startuml
title pg:: rule-list AI (battle.md §6 — port of Unity AI/)
hide empty members

class AIBehaviour <<definition>> {
  +activeMode : string
  +rulesByMode : map<string, AIRule[]>
}
class AIRule {
  +conditions : AICondition[]  .. AND ..
  +decision : AIDecision
}
abstract class AICondition <<polymorphic>> {
  +isMet(unit, BattleContext&) : bool
}
abstract class AIDecision <<polymorphic>> {
  +produce(unit, BattleContext&) : optional<BattleAction>
}
class "enemyWithinRange {range}\nallyHpBelow {percent}\nselfHpBelow {percent}\nhasStatus {status, on}\ncanCast {ability}" as Conditions
class "castAbility {ability, target}\nmoveTowardNearestEnemy\nmoveAwayFromEnemies\nendTurn" as Decisions
AICondition <|-- Conditions
AIDecision <|-- Decisions
AIBehaviour *-- AIRule
AIRule o-- AICondition
AIRule o-- AIDecision

class EnemyTurnPhase {
  .. top-down: first rule with all conditions
     met AND a legal produced action wins;
     nothing legal → EndTurnAction ..
}
EnemyTurnPhase ..> AIBehaviour : evaluates
EnemyTurnPhase ..> "BattleActionValidator" : legality
note bottom of Decisions
  castAbility may prepend movement into
  cast range when MP allows (path toward
  nearest valid casting cell).
end note
@enduml
