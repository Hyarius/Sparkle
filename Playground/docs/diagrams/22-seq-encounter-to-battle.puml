@startuml
title Encounter → in-place battle overlay (Plan Gamma, D03)
participant "EncounterEmitter" as Enc
participant "EncounterResolver" as Res
participant "EventCenter" as Bus
participant "EncounterService" as Svc
participant "BoardBuilder" as BB
participant "ModeManager" as MM
participant "BattleMode" as BM
participant "BattleCoordinator" as Coord
participant "TacticalCameraLogic" as Cam

Enc -> Res : tryRoll(rule, playerCell)
Res --> Enc : team (weighted pick, tier by badges)
Enc -> Bus : encounterTriggered(spawn)
Bus -> Svc : (subscription)
Svc -> Svc : instantiate enemy CreatureUnits\n(completedNodes → applyProgress), attach AI
Svc -> BB : fromWorld(world, playerCell, spawn.boardSize)
BB --> Svc : BoardData{worldAnchor, nav graph,\ndeployment zones, border}
note right : live view over world voxels —\nno copy, no scene swap
Svc -> Bus : battleStarted(BattleContext)
Bus -> MM : (subscription)
MM -> BM : enter(ctx)
BM -> BM : freeze exploration triggers,\nactivate battle input + overlay view
BM -> Cam : blend exploration pose → tactical framing (~0.6s)
BM -> Coord : start → SetupPhase → PlacementPhase…
... battle runs (see 23-seq) ...
Coord -> Bus : battleResolved(ctx, winner)
Bus -> MM : (subscription)
MM -> BM : exit() — drop overlay, unbind input
MM -> "ExplorationMode" : enter() — camera blends back,\nfree-roam resumes (loss → respawn at heal point)
@enduml
