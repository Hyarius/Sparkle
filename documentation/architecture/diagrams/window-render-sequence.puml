@startuml
title Window Render Flow

skinparam ParticipantPadding 8

participant "Render loop" as RenderLoop
participant "Window" as Window
participant "WindowHost" as Host
participant "GPUPlatformRuntime" as GPURuntime
participant "RenderContext" as Context
participant "RenderModule" as RenderModule
participant "RenderSnapshot" as Snapshot
participant "RenderUnit" as Unit
participant "RenderCommand" as Command

RenderLoop -> Window : render()
activate Window

alt window is closed
	Window -> Host : releaseRenderContext()
	Window --> RenderLoop
else window is open
	Window -> Window : _drainPendingRenderActions()
	note right of Window
	NotifyResize and SetVSync are coalesced;
	only the latest value of each action type
	is kept for this render pass.
	end note
	Window -> Host : makeCurrent()
	activate Host
	Host -> Host : bind or validate render thread
	alt render context missing and surface valid
		Host -> GPURuntime : createRenderContext(frame)
		GPURuntime --> Host : unique_ptr<RenderContext>
		Host -> Context : surfaceState().setRect(frame.rect())
	else surface invalid
		Host --> Window : false
		Window --> RenderLoop
	end
	Host -> Context : makeCurrent()
	Host --> Window : true
	deactivate Host

	loop render actions
		alt NotifyResize
			Window -> Host : notifyFrameResized(rect)
			Host -> Context : notifyResize(rect)
		else SetVSync
			Window -> Host : setVSync(enabled)
			Host -> Context : setVSync(enabled)
		end
	end

	Window -> Host : renderContext()
	Host --> Window : RenderContext&
	Window -> RenderModule : render(context)
	RenderModule -> RenderModule : currentSnapshot()
	alt snapshot exists
		RenderModule -> Snapshot : execute(context)
		loop each render unit
			Snapshot -> Unit : execute(context)
			loop each command
				Unit -> Command : execute(context)
			end
		end
	end
	Window -> Host : present()
	Host -> Context : present()
end

deactivate Window

@enduml
