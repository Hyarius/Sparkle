@startuml
title Application and Windowing - Overview

skinparam classAttributeIconSize 0

namespace spk {
	class Application {
		- Configuration _configuration
		- WindowRegistry _windowRegistry
		- shared_ptr<PlatformRuntime> _platformRuntime
		- shared_ptr<GPUPlatformRuntime> _gpuPlatformRuntime
		+ createWindow(id, configuration) : WindowHandle
		+ window(id) : WindowHandle
		+ containsWindow(id) : bool
		+ requestWindowClosing(id)
		+ quit(exitCode)
		+ stop()
		+ run() : int
	}

	class WindowRegistry {
		- unordered_map<WindowID, Entry> _windows
		+ createWindow(id, platformRuntime, gpuRuntime, configuration) : WindowHandle
		+ window(id) : WindowHandle
		+ contains(id) : bool
		+ size() : size_t
		+ removeClosedWindows()
		+ requestWindowClosing(id)
	}

	class WindowHandle {
		- weak_ptr<Window> _window
		+ isValid() : bool
		+ expired() : bool
		+ isClosed() : bool
		+ requestClosure()
		+ setTitle(title)
		+ resize(rect)
		+ setVSync(enabled)
		+ rect() : Rect2D
		+ centralWidget() : Widget&
	}

	class Window {
		- Widget _rootWidget
		- WindowHost _host
		- FrameModule _frameModule
		- MouseModule _mouseModule
		- KeyboardModule _keyboardModule
		- UpdateModule _updateModule
		- RenderModule _renderModule
		+ executePendingPlatformActions()
		+ update()
		+ render()
		+ requestClosure()
		+ isClosed() : bool
		+ isReadyForDisposal() : bool
	}

	class WindowHost {
		+ resize(rect)
		+ setTitle(title)
		+ requestClosure()
		+ validateClosure()
		+ makeCurrent() : bool
		+ renderContext() : RenderContext&
		+ present()
		+ releaseFrame()
		+ releaseRenderContext()
	}

	class PlatformRuntime {
		+ createFrame(rect, title) : unique_ptr<IFrame>
		+ pollEvents()
	}

	class GPUPlatformRuntime {
		+ createRenderContext(frame) : unique_ptr<RenderContext>
		+ waitUntilWorkDone()
	}

	class Widget
	class IFrame
	class RenderContext
}

spk.Application *-- spk.WindowRegistry
spk.Application --> spk.PlatformRuntime
spk.Application --> spk.GPUPlatformRuntime
spk.WindowRegistry o-- "0..*" spk.Window
spk.WindowRegistry ..> spk.WindowHandle : returns
spk.WindowHandle ..> spk.Window : weak reference
spk.Window *-- spk.WindowHost
spk.Window *-- spk.Widget
spk.Window *-- spk.FrameModule
spk.Window *-- spk.MouseModule
spk.Window *-- spk.KeyboardModule
spk.Window *-- spk.UpdateModule
spk.Window *-- spk.RenderModule
spk.WindowHost --> spk.IFrame
spk.WindowHost --> spk.GPUPlatformRuntime
spk.WindowHost --> spk.RenderContext
spk.PlatformRuntime --> spk.IFrame : creates
spk.GPUPlatformRuntime --> spk.RenderContext : creates

note right of spk.Application
Application owns the registry and runtime loops.
It returns WindowHandle values so callers do not
own Window lifetime directly.
end note

note bottom of spk.Window
Detailed module queues, render snapshots,
actions, closure state, and host threading
are documented in the focused window diagrams.
end note

@enduml
