@startuml
title Window Event Routing

skinparam ParticipantPadding 8

participant "Concrete IFrame\n(platform thread)" as Frame
participant "IFrame family providers" as Provider
participant "WindowHost" as Host
participant "Window\n(orchestration)" as Window
participant "Update thread" as UpdateThread
participant "Frame/Mouse/Keyboard Module\n(thread-safe family queues)" as Module
participant "Widget tree" as Widget

Frame -> Provider : _emitFrameEvent(FrameEventRecord)
Provider -> Host : subscribed frame callback(event)
Host -> Window : _enqueueFrameEvent(event)
Window -> Module : FrameModule.pushEvent(event)

Frame -> Provider : _emitMouseEvent(MouseEventRecord)
Provider -> Host : subscribed mouse callback(event)
Host -> Window : _enqueueMouseEvent(event)
Window -> Module : MouseModule.pushEvent(event)

Frame -> Provider : _emitKeyboardEvent(KeyboardEventRecord)
Provider -> Host : subscribed keyboard callback(event)
Host -> Window : _enqueueKeyboardEvent(event)
Window -> Module : KeyboardModule.pushEvent(event)

note right of Window
Reception only pushes event records into
module-owned queues. No widget or device
state work is performed on the platform
polling path.
end note

... update loop ...

UpdateThread -> Window : update()
Window -> Module : FrameModule.processEvents(callback)

loop each frame event, FIFO inside frame family
	Module -> Widget : dispatchFrameEvent(FrameEventRecord)
	Widget -> Widget : _onWindow*Event(EventView<T>)
	Module -> Window : callback(event, isConsumed)
	alt WindowResizedRecord
		Window -> Window : enqueue RenderAction.NotifyResize
	end
	alt WindowCloseRequestedRecord and not consumed
		Window -> Window : enqueue PlatformAction.ValidateClosure
	end
end

Window -> Module : MouseModule.processEvents()
loop each mouse event, FIFO inside mouse family
	Module -> Module : update Mouse state
	Module -> Widget : dispatchMouseEvent(MouseEventRecord, Mouse)
	Widget -> Widget : _onMouse*Event(DeviceEventView<T,Mouse>)
end

Window -> Module : KeyboardModule.processEvents()
loop each keyboard event, FIFO inside keyboard family
	Module -> Module : update Keyboard state
	Module -> Widget : dispatchKeyboardEvent(KeyboardEventRecord, Keyboard)
	Widget -> Widget : _onKey/Text*Event(DeviceEventView<T,Keyboard>)
end

Window -> Module : UpdateModule.update()
Module -> Widget : update(UpdateTick)
Window -> Window : _rebuildRenderSnapshot()

@enduml
