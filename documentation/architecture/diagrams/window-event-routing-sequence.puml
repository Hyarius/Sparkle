@startuml
title Window Event Routing

skinparam ParticipantPadding 8

participant "Concrete IFrame\n(platform thread)" as Frame
participant "IFrame family providers" as Provider
participant "WindowHost" as Host
participant "Window\n(thread-safe queues)" as Window
participant "Update thread" as UpdateThread
participant "Frame/Mouse/Keyboard Module" as Module
participant "Widget tree" as Widget

Frame -> Provider : _emitFrameEventRecord(FrameEventRecord)
Provider -> Host : subscribed frame callback(event)
Host -> Window : _enqueueFrameEventRecord(event)

Frame -> Provider : _emitMouseEventRecord(MouseEventRecord)
Provider -> Host : subscribed mouse callback(event)
Host -> Window : _enqueueMouseEventRecord(event)

Frame -> Provider : _emitKeyboardEventRecord(KeyboardEventRecord)
Provider -> Host : subscribed keyboard callback(event)
Host -> Window : _enqueueKeyboardEventRecord(event)

note right of Window
Reception only copies event data into
family-specific queues. No widget or
device state work is performed on the
platform polling path.
end note

... update loop ...

UpdateThread -> Window : update()
Window -> Window : drain frame, mouse, keyboard queues
Window -> Window : merge by internal sequence

loop each queued event reference
	alt frame event
		Window -> Module : FrameModule.pushEvent(FrameEventRecord)
		Module -> Widget : dispatchFrameEventRecord(FrameEventRecord)
		Widget -> Widget : _onWindow*Event(EventView<T>)
		alt WindowResizedRecord
			Window -> Window : enqueue RenderAction.NotifyResize
		end
		alt WindowCloseRequestedRecord and not consumed
			Window -> Window : enqueue PlatformAction.ValidateClosure
		end
	else mouse event
		Window -> Module : MouseModule.pushEvent(MouseEventRecord)
		Module -> Module : update Mouse state
		Module -> Widget : dispatchMouseEventRecord(MouseEventRecord, Mouse)
		Widget -> Widget : _onMouse*Event(DeviceEventView<T,Mouse>)
	else keyboard event
		Window -> Module : KeyboardModule.pushEvent(KeyboardEventRecord)
		Module -> Module : update Keyboard state
		Module -> Widget : dispatchKeyboardEventRecord(KeyboardEventRecord, Keyboard)
		Widget -> Widget : _onKey/Text*Event(DeviceEventView<T,Keyboard>)
	end
end

Window -> Module : UpdateModule.update()
Module -> Widget : update(UpdateTick)
Window -> Window : _rebuildRenderSnapshot()

@enduml
