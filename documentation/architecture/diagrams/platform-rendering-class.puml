@startuml
title Platform and Rendering Abstractions - Class View

skinparam classAttributeIconSize 0

namespace spk {
	interface IPlatformRuntime {
		+ createFrame(rect, title) : unique_ptr<IFrame>
		+ pollEvents()
	}

	abstract class IFrame {
		- EventContractProvider _mouseEventContractProvider
		- EventContractProvider _keyboardEventContractProvider
		- EventContractProvider _frameEventContractProvider
		- shared_ptr<ISurfaceState> _surfaceState
		# _emitMouseEvent(event)
		# _emitKeyboardEvent(event)
		# _emitFrameEvent(event)
		# _invalidateSurfaceState()
		+ resize(rect)
		+ setTitle(title)
		+ requestClosure()
		+ validateClosure()
		+ surfaceState() : shared_ptr<ISurfaceState>
	}

	class ISurfaceState {
		- atomic<bool> _isValid
		+ invalidate()
		+ isValid() : bool
	}

	interface IGPUPlatformRuntime {
		+ createRenderContext(frame) : unique_ptr<IRenderContext>
	}

	abstract class IRenderContext {
		- shared_ptr<ISurfaceState> _surfaceState
		+ invalidate()
		+ isValid() : bool
		+ makeCurrent()
		+ present()
		+ setVSync(enabled)
		+ notifyResize(rect)
	}

	abstract class RenderCommand {
		+ execute()
	}

	class RenderUnit {
		- vector<unique_ptr<RenderCommand>> _commands
		+ commands() : vector<unique_ptr<RenderCommand>>&
		+ execute()
	}

	class RenderUnitBuilder {
		- vector<unique_ptr<RenderCommand>> _commands
		+ emplace<TCommand>(args...) : TCommand&
		+ build() : RenderUnit
	}

	class RenderSnapshot {
		- vector<shared_ptr<const RenderUnit>> _units
		+ units() : vector<shared_ptr<const RenderUnit>>&
		+ execute()
	}

	class RenderSnapshotBuilder {
		- vector<shared_ptr<const RenderUnit>> _units
		+ append(unit)
		+ build() : RenderSnapshot
	}

	class RenderModule {
		- shared_ptr<const RenderSnapshot> _currentSnapshot
		- mutex _snapshotMutex
		+ publishSnapshot(snapshot)
		+ currentSnapshot() : shared_ptr<const RenderSnapshot>
		+ render()
	}
}

spk.IPlatformRuntime --> spk.IFrame : creates
spk.IFrame *-- spk.ISurfaceState
spk.IGPUPlatformRuntime --> spk.IRenderContext : creates
spk.IGPUPlatformRuntime --> spk.IFrame : reads backend data from
spk.IRenderContext --> spk.ISurfaceState
spk.RenderUnit *-- "0..*" spk.RenderCommand
spk.RenderUnitBuilder *-- "0..*" spk.RenderCommand
spk.RenderUnitBuilder ..> spk.RenderUnit : builds
spk.RenderSnapshot o-- "0..*" spk.RenderUnit
spk.RenderSnapshotBuilder o-- "0..*" spk.RenderUnit
spk.RenderSnapshotBuilder ..> spk.RenderSnapshot : builds
spk.RenderModule o-- spk.RenderSnapshot

note bottom of spk.ISurfaceState
Surface invalidation is a cross-thread signal.
The render thread still owns render-context teardown.
end note

note right of spk.RenderUnit
RenderUnits are immutable after publication.
Dirty widgets replace the shared unit instead
of mutating command storage in place.
end note

@enduml
