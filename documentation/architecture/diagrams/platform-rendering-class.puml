@startuml
title Platform and Rendering Abstractions - Class View

skinparam classAttributeIconSize 0

namespace spk {
	class PlatformRuntime {
		- shared_ptr<WindowClass> _windowClass
		+ createFrame(rect, title) : unique_ptr<IFrame>
		+ pollEvents()
	}

	abstract class IFrame {
		- EventContractProvider _mouseEventContractProvider
		- EventContractProvider _keyboardEventContractProvider
		- EventContractProvider _frameEventContractProvider
		- shared_ptr<SurfaceState> _surfaceState
		# _emitMouseEvent(event)
		# _emitKeyboardEvent(event)
		# _emitFrameEvent(event)
		# _invalidateSurfaceState()
		+ resize(rect)
		+ setTitle(title)
		+ hide()
		+ requestClosure()
		+ validateClosure()
		+ rect() : Rect2D
		+ title() : string
		+ surfaceState() : shared_ptr<SurfaceState>
	}

	class SurfaceState {
		- atomic<bool> _isValid
		- Rect2D _rect
		+ invalidate()
		+ isValid() : bool
		+ setRect(rect)
		+ rect() : Rect2D
	}

	class GPUPlatformRuntime {
		+ createRenderContext(frame) : unique_ptr<RenderContext>
		+ waitUntilWorkDone()
		+ saveScreenshot(path, rect)
	}

	class RenderContext {
		- shared_ptr<SurfaceState> _surfaceState
		- bool _valid
		+ invalidate()
		+ isValid() : bool
		+ supportsOpenGLCommands() : bool
		+ makeCurrent()
		+ present()
		+ setVSync(enabled)
		+ notifyResize(rect)
	}

	abstract class RenderCommand {
		+ execute(renderContext)
	}

	class RenderUnit {
		- vector<unique_ptr<RenderCommand>> _commands
		+ empty() : bool
		+ size() : size_t
		+ commands() : const vector<unique_ptr<RenderCommand>>&
		+ execute(renderContext)
	}

	class RenderUnitBuilder {
		- vector<unique_ptr<RenderCommand>> _commands
		+ clear()
		+ empty() : bool
		+ size() : size_t
		+ emplace<TCommand>(args...) : TCommand&
		+ build() : RenderUnit
	}

	class RenderSnapshot {
		- vector<shared_ptr<RenderUnit>> _units
		+ empty() : bool
		+ size() : size_t
		+ units() : const vector<shared_ptr<RenderUnit>>&
		+ execute(renderContext)
	}

	class RenderSnapshotBuilder {
		- vector<shared_ptr<RenderUnit>> _units
		+ clear()
		+ append(unit)
		+ empty() : bool
		+ size() : size_t
		+ units() : const vector<shared_ptr<RenderUnit>>&
		+ build() : RenderSnapshot
	}

	class RenderModule {
		- shared_ptr<RenderSnapshot> _currentSnapshot
		- mutex _snapshotMutex
		+ publishSnapshot(snapshot)
		+ currentSnapshot() : shared_ptr<RenderSnapshot>
		+ render(renderContext)
	}
}

spk.PlatformRuntime --> spk.IFrame : creates
spk.IFrame *-- spk.SurfaceState
spk.GPUPlatformRuntime --> spk.RenderContext : creates
spk.GPUPlatformRuntime --> spk.IFrame : reads backend data from
spk.RenderContext --> spk.SurfaceState
spk.RenderCommand ..> spk.RenderContext : receives during execution
spk.RenderUnit *-- "0..*" spk.RenderCommand
spk.RenderUnitBuilder *-- "0..*" spk.RenderCommand
spk.RenderUnitBuilder ..> spk.RenderUnit : builds
spk.RenderSnapshot o-- "0..*" spk.RenderUnit
spk.RenderSnapshotBuilder o-- "0..*" spk.RenderUnit
spk.RenderSnapshotBuilder ..> spk.RenderSnapshot : builds
spk.RenderModule o-- spk.RenderSnapshot

note bottom of spk.SurfaceState
Surface invalidation is a cross-thread signal.
The render thread still owns render-context teardown.
end note

note right of spk.RenderUnit
Widgets replace dirty render units instead of
mutating command storage during snapshot rebuilds.
Render command execution may update backend state.
end note

@enduml
