@startuml
title Window Modules - Class View

skinparam classAttributeIconSize 0

namespace spk {
	abstract class IModule {
		- Widget* _widget
		+ bind(widget)
		+ widget() : Widget*
	}

	class FrameModule {
		- ThreadSafeDeque<FrameEventRecord> _events
		+ pushEvent(FrameEventRecord)
		+ processEvents(callback)
		- _treatEvent(FrameEventRecord)
	}

	class MouseModule {
		- Mouse _mouse
		- ThreadSafeDeque<MouseEventRecord> _events
		+ pushEvent(MouseEventRecord)
		+ processEvents()
		+ mouse() : Mouse&
		- _treatEvent(MouseEventRecord)
	}

	class KeyboardModule {
		- Keyboard _keyboard
		- ThreadSafeDeque<KeyboardEventRecord> _events
		+ pushEvent(KeyboardEventRecord)
		+ processEvents()
		+ keyboard() : Keyboard&
		- _treatEvent(KeyboardEventRecord)
	}

	class UpdateModule {
		- optional<Timestamp> _lastTimestamp
		- Mouse* _mouse
		- Keyboard* _keyboard
		+ bindInputs(mouse, keyboard)
		+ update()
	}

	class RenderModule {
		+ render(builder)
	}

	class "ThreadSafeDeque<T>" as ThreadSafeDeque {
		- deque<T> _values
		- mutex _mutex
		+ pushBack(value)
		+ popFront(output) : bool
		+ drain() : vector<T>
		+ clear()
	}

	class Window {
		- FrameModule _frameModule
		- MouseModule _mouseModule
		- KeyboardModule _keyboardModule
		- UpdateModule _updateModule
		- RenderModule _renderModule
	}

	class Widget {
		+ dispatchFrameEvent(FrameEventRecord)
		+ dispatchMouseEvent(MouseEventRecord, Mouse)
		+ dispatchKeyboardEvent(KeyboardEventRecord, Keyboard)
		# _onWindowResizedEvent(WindowResizedEvent)
		# _onMouseMovedEvent(MouseMovedEvent)
		# _onKeyPressedEvent(KeyPressedEvent)
		+ update(tick)
		+ appendRenderCommands(builder)
	}
}

spk.IModule <|-- spk.FrameModule
spk.IModule <|-- spk.MouseModule
spk.IModule <|-- spk.KeyboardModule
spk.IModule <|-- spk.UpdateModule

spk.Window *-- spk.FrameModule
spk.Window *-- spk.MouseModule
spk.Window *-- spk.KeyboardModule
spk.Window *-- spk.UpdateModule
spk.Window *-- spk.RenderModule

spk.IModule --> spk.Widget : bound root
spk.FrameModule *-- spk.ThreadSafeDeque
spk.MouseModule *-- spk.ThreadSafeDeque
spk.KeyboardModule *-- spk.ThreadSafeDeque
spk.UpdateModule --> spk.Mouse
spk.UpdateModule --> spk.Keyboard
spk.RenderModule --> spk.RenderCommandBuilder

note bottom of spk.MouseModule
MouseModule updates Mouse state before
dispatching the event into the widget tree.
end note

note bottom of spk.FrameModule
Modules consume already separated event
families from their own thread-safe queues.
They do not reclassify a generic payload event.
end note

@enduml
