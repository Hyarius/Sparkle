@startuml
title Binary Field Explicit Sections

skinparam ParticipantPadding 8

participant "User" as User
participant "BinaryField" as Field
participant "Section registry" as Sections
participant "External bytes" as Bytes

User -> Field : BinaryField(data, size)
Field -> Sections : create root section

User -> Field : addObject("transform", offset, size)
Field -> Sections : validate parent bounds
Field -> Sections : append object section
Field --> User : BinaryField

User -> Field : addValue("x", offset, sizeof(float))
Field -> Sections : validate parent bounds
Field -> Sections : append value section

User -> Field : operator[]("transform")["x"]
Field -> Sections : lookup child section
Field --> User : BinaryField

User -> Field : operator=<float>(value)
Field -> Sections : validate exact byte size
Field -> Bytes : memcpy(value, section.data)

User -> Field : bytes()
Field --> User : span at section data and size

@enduml
