{
	"version": 3,
	"cmakeMinimumRequired": {
		"major": 3,
		"minor": 16,
		"patch": 0
	},
	"configurePresets": [
		{
			"name": "default",
			"hidden": true,
			"generator": "Ninja",
			"binaryDir": "${sourceDir}/build/${presetName}",
			"toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
			"cacheVariables": {
				"CMAKE_CXX_STANDARD": "20",
				"CMAKE_CXX_STANDARD_REQUIRED": "ON",
				"VCPKG_TARGET_TRIPLET": "x64-windows",
				"CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
				"CMAKE_INSTALL_PREFIX": "$env{ProgramFiles(x86)}/EreliaStudio/Sparkle",
				"SPARKLE_GPU_BACKEND": "OPENGL"
			}
		},
		{
			"name": "debug",
			"inherits": "default",
			"description": "Configure for Debug build",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug"
			}
		},
		{
			"name": "release",
			"inherits": "default",
			"description": "Configure for Release build",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release"
			}
		},
		{
			"name": "test",
			"inherits": "default",
			"description": "Configure for Release build with Test Units",
			"cacheVariables": {
				"ENABLE_TESTS": "ON",
				"CMAKE_BUILD_TYPE": "Release"
			}
		},
		{
			"name": "playground",
			"inherits": "default",
			"description": "Configure for Debug build with Playground executable",
			"cacheVariables": {
				"ENABLE_PLAYGROUND": "ON",
				"CMAKE_BUILD_TYPE": "Debug"
			}
		}
	],
	"buildPresets": [
		{
			"name": "default",
			"hidden": true,
			"configurePreset": "default"
		},
		{
			"name": "debug",
			"configurePreset": "debug"
		},
		{
			"name": "release",
			"configurePreset": "release"
		},
		{
			"name": "test",
			"configurePreset": "test"
		},
		{
			"name": "playground",
			"configurePreset": "playground",
			"targets": [
				"SparklePlayground"
			]
		}
	],
	"testPresets": [
		{
			"name": "default",
			"hidden": true,
			"configurePreset": "default"
		},
		{
			"name": "debug",
			"configurePreset": "debug"
		},
		{
			"name": "release",
			"configurePreset": "release"
		},
		{
			"name": "test",
			"configurePreset": "test"
		},
		{
			"name": "playground",
			"configurePreset": "playground"
		}
	]
}
